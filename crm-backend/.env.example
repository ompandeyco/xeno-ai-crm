# CRM Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to Git.

PORT=5001
NODE_ENV=development

# MongoDB connection string from MongoDB Atlas or local
MONGO_URI=mongodb://localhost:27017/xeno-crm

# URL of the Channel Service (for dispatching messages)
CHANNEL_SERVICE_URL=http://localhost:5002

# Gemini API Key (will be used when AI features are implemented)
GEMINI_API_KEY=your_gemini_api_key_here
